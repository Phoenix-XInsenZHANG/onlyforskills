{
  "permissions": {
    "allow": [
      "Bash(git checkout -b *)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git init:*)",
      "Bash(gh auth:*)",
      "Bash(gh repo:*)",
      "Bash(for skill:*)",
      "Bash(for file:*)",
      "Bash(mv *:*)",
      "Bash(do cp:*)",
      "Bash(done)",
      "Bash(do)",
      "Skill(web-testing)",
      "Skill(web-testing:*)"
    ],
    "deny": [
      "Bash(git commit*--no-verify*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-bash.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-edit-lint.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'CRITICAL RULES (post-compaction): Read .claude/rules/core.md for Rules 0-9. Domain rules auto-load from .claude/rules/ when editing matching files. Enforcement: types > guards > lints > hooks > rules > docs. Read CARD-CONTEXT-LATEST for session state.'"
          }
        ]
      }
    ]
  }
}
