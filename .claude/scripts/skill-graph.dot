  "directus-schema" -> "backend-extension";
  "directus-schema" -> "migration";
  "executing-plans" -> "finishing-branch";
  "executing-plans" -> "git-worktrees";
  "executing-plans" -> "subagent-driven-development";
  "executing-plans" -> "verification";
  "executing-plans" -> "writing-plans";
  "landing-audit" -> "landing-page";
  "meta-evaluation" -> "agent-teams";
  "migration" -> "directus-schema";
  "router" -> "web-testing";
  "skill-creator" -> "general";
  "skill-creator" -> "pdf";
  "subagent-driven-development" -> "executing-plans";
  "subagent-driven-development" -> "finishing-branch";
