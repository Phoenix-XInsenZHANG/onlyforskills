  // Legend
  subgraph cluster_legend {
    label="Categories"; style=dashed; fontname="Helvetica";
    "legend_workflow" [label="workflow", fillcolor="#FFE0B2"];
    "legend_review" [label="review", fillcolor="#C8E6C9"];
    "legend_agents" [label="agents", fillcolor="#E1BEE7"];
    "legend_docs" [label="docs", fillcolor="#B3E5FC"];
