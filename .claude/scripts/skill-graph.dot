  "backend-extension" [fillcolor="#D7CCC8"];
  "d11-frontend" [fillcolor="#D7CCC8"];
  "skill-creator" [fillcolor="#F0F4C3"];
  "writing-skills" [fillcolor="#F0F4C3"];
  "router" [fillcolor="#F0F4C3"];
  "onboard" [fillcolor="#F0F4C3"];
  "progress" [fillcolor="#F0F4C3"];
  "team-health" [fillcolor="#F0F4C3"];

  "ai-workflow" -> "api-testing";
  "ai-workflow" -> "directus-schema";
  "ai-workflow" -> "pm-comments";
  "api-testing" -> "ai-workflow";
  "backend-extension" -> "api-testing";
  "backend-extension" -> "directus-schema";
